\@writefile{toc}{\contentsline {paragraph}{تاثیر نسبت طراحی}{6}{paragraph*.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces  رفتار خروجی گیت NOT به ازای مقادیر مختلف $\beta $ در لبه پایین‌رونده (اعمال ولتاژ یک منطقی به ورودی)   همان‌گونه که مشاهده می‌شود، با افزایش نسبت طراحی $\beta $، عرض ترانزیستور PMOS افزایش می‌یابد. این امر باعث بزرگتر شدن خازن‌های بدنه و سورس و درین نرانزیستور شده و در نتیجه، زمان دشارژ خازن توسط شبکه پایین‌بر طولانی‌تر و تأخیر نزولی بیشتر می‌شود. (چرا که قدرت ترانزیستورهای NMOS ثابت مانده است.) }}{6}{figure.4}\protected@file@percent }
\newlabel{fig:not-fall}{{4}{6}{رفتار خروجی گیت NOT به ازای مقادیر مختلف $\beta $ در لبه پایین‌رونده (اعمال ولتاژ یک منطقی به ورودی) \\ همان‌گونه که مشاهده می‌شود، با افزایش نسبت طراحی $\beta $، عرض ترانزیستور PMOS افزایش می‌یابد. این امر باعث بزرگتر شدن خازن‌های بدنه و سورس و درین نرانزیستور شده و در نتیجه، زمان دشارژ خازن توسط شبکه پایین‌بر طولانی‌تر و تأخیر نزولی بیشتر می‌شود. (چرا که قدرت ترانزیستورهای NMOS ثابت مانده است.)}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces  رفتار خروجی گیت NOT به ازای مقادیر مختلف $\beta $ در لبه بالارونده (اعمال ولتاژ صفر منطقی به ورودی)   همان‌گونه که مشاهده می‌شود، با افزایش نسبت طراحی $\beta $ و بزرگتر شدن عرض ترانزیستور PMOS ، مقاومت معادل مسیر بالابر کاهش می‌یابد. در نتیجه، جریان‌دهی ترانزیستور PMOS بیشتر شده و خازن پارازیتی خروجی گیت سریع‌تر شارژ می‌شود که این امر منجر به کاهش تأخیر صعودی می‌گردد. }}{6}{figure.5}\protected@file@percent }
\newlabel{fig:not-rise}{{5}{6}{رفتار خروجی گیت NOT به ازای مقادیر مختلف $\beta $ در لبه بالارونده (اعمال ولتاژ صفر منطقی به ورودی) \\ همان‌گونه که مشاهده می‌شود، با افزایش نسبت طراحی $\beta $ و بزرگتر شدن عرض ترانزیستور PMOS ، مقاومت معادل مسیر بالابر کاهش می‌یابد. در نتیجه، جریان‌دهی ترانزیستور PMOS بیشتر شده و خازن پارازیتی خروجی گیت سریع‌تر شارژ می‌شود که این امر منجر به کاهش تأخیر صعودی می‌گردد}{figure.5}{}}
