\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces  تاثیر دما و \lr {$\beta $} بر تاخیر \lr {$t_{pLH}$}  با افزایش دما تاخیرها افزایش پیدا می‌کنند همچنین با افزایش $\beta $ مقاومت معادل شاخه بالابر کاهش می‌یابد و تاخیر کاهش می‌یابد. }}{9}{figure.11}\protected@file@percent }
\newlabel{fig:not-plot-tplh}{{11}{9}{تاثیر دما و \lr {$\beta $} بر تاخیر \lr {$t_{pLH}$}\\ با افزایش دما تاخیرها افزایش پیدا می‌کنند همچنین با افزایش $\beta $ مقاومت معادل شاخه بالابر کاهش می‌یابد و تاخیر کاهش می‌یابد}{figure.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces  تاثیر دما و \lr {$\beta $} بر تاخیر \lr {$t_p$} همانطور که قابل مشاهده است به صورت میانگین افزایش $\beta $ تا جایی برای کم کردن تاخیر میانگین مدار کار ساز است و بیشتر از آن موجب افزایش بیشتر تاخیر به دلیل بزرگ شدن خازن‌های پارازیتی شاخه‌بالا بر می‌شود.. }}{9}{figure.12}\protected@file@percent }
\newlabel{fig:not-plot-tp}{{12}{9}{تاثیر دما و \lr {$\beta $} بر تاخیر \lr {$t_p$} همانطور که قابل مشاهده است به صورت میانگین افزایش $\beta $ تا جایی برای کم کردن تاخیر میانگین مدار کار ساز است و بیشتر از آن موجب افزایش بیشتر تاخیر به دلیل بزرگ شدن خازن‌های پارازیتی شاخه‌بالا بر می‌شود.}{figure.12}{}}
